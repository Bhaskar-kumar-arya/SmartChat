{
  "id": "com.smartchat.hello-bot",
  "name": "Comprehensive Bot",
  "version": "1.1.0",
  "apiVersion": "1",
  "description": "A comprehensive test extension that demonstrates dedicated chat, storage, scheduling, and UI notifications.",
  "main": "index.js",
  "permissions": [
    "log",
    "ui:dedicated_chat",
    "events:extension:chat-message",
    "storage:read",
    "storage:write",
    "scheduler",
    "ui:notification"
  ],
  "dedicatedChat": {
    "name": "Comprehensive Bot",
    "avatarEmoji": "🛠️",
    "commands": [
      { "command": "ping", "description": "Basic text reply test" },
      { "command": "card", "description": "Tests interactive card rendering" },
      { "command": "toast", "description": "Tests global app toasts" },
      { "command": "notify", "description": "Tests OS notifications" },
      { "command": "counter", "description": "Tests persistent KV storage" },
      { "command": "timer", "description": "Tests the extension scheduler" }
    ]
  }
}
