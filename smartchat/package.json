{
  "name": "smartchat",
  "version": "1.0.0",
  "description": "An Electron application with React and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "node scripts/generate-docs.js && electron-vite dev",
    "test": "vitest",
    "test:rebuild:node": "npm rebuild better-sqlite3",
    "test:rebuild:electron": "npx @electron/rebuild --force -v 39.8.2",
    "test:run": "npm run test:rebuild:node && vitest run",
    "test:run:all": "npm run test:rebuild:node && vitest run --fileParallelism=false --maxWorkers=1",
    "//test_instruction_1_single": "To run a single test: 'npm run test:run -- <file-path>'",
    "//test_instruction_2_all": "To run all tests sequentially (do not run in parallel): 'npm run test:run:all'",
    "//test_instruction_3_critical": "CRITICAL: After testing, you must run 'npm run test:rebuild:electron' before running the app ('npm run dev') again. Tests rebuild for Node.js, while the app rebuilds for Electron.",
    "build": "node scripts/generate-template.js && node scripts/generate-docs.js && npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-fonts/noto-color-emoji": "^1.2.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@google/genai": "^1.48.0",
    "@lmstudio/sdk": "^1.5.0",
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@tiptap/react": "^3.20.3",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "@xenova/transformers": "^2.17.2",
    "adm-zip": "^0.6.0",
    "better-sqlite3": "^12.8.0",
    "electron-updater": "^6.3.9",
    "emoji-picker-react": "^4.19.1",
    "emoji-regex": "^10.6.0",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "groq-sdk": "^1.2.1",
    "hdbscan-ts": "^1.0.17",
    "katex": "^0.17.0",
    "link-preview-js": "^3.2.0",
    "lucide-react": "^0.577.0",
    "ml-kmeans": "^7.0.0",
    "node-cache": "^5.1.2",
    "node-cron": "^4.6.0",
    "node-webpmux": "^3.2.1",
    "onnxruntime-node": "^1.24.3",
    "openai": "^6.34.0",
    "qrcode.react": "^4.2.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sqlite-vec": "^0.1.9",
    "tailwindcss": "^4.2.1",
    "umap-js": "^1.4.0",
    "wavesurfer.js": "^7.12.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/adm-zip": "^0.5.8",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^22.19.1",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "madge": "^8.0.0",
    "node-llama-cpp": "^3.18.1",
    "prettier": "^3.7.4",
    "prisma": "^7.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.9"
  }
}
